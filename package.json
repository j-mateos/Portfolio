{
    "name": "portfolio",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "bun vite .",
        "format": "bun prettier . --write --log-level warn",
        "lint": "bun eslint . --fix",
        "fix": "bun run format && bun run lint",
        "test": "bun vitest .",
        "build": "bun vite build .",
        "preview": "bun run build && bun vite preview .",
        "deps-check": "bunx knip",
        "deps-audit": "bun audit",
        "deps-update": "bun update --latest && bun install",
        "clean-build": "rm -rf dist",
        "clean-deps": "rm -rf node_modules bun.lock"
    },
    "dependencies": {
        "@eslint/js": "10.0.1",
        "@vercel/speed-insights": "2.0.0",
        "i18next": "26.0.3",
        "i18next-http-backend": "3.0.4",
        "prettier": "3.8.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-i18next": "17.0.2"
    },
    "devDependencies": {
        "@eslint/compat": "2.0.4",
        "@eslint/eslintrc": "3.3.5",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/ui": "4.1.3",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "globals": "17.4.0",
        "jsdom": "29.0.2",
        "vite": "8.0.7",
        "vitest": "4.1.3"
    }
}
